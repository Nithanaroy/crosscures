# Epic FHIR API Configuration
# Copy this file to .env and fill in your credentials

# =============================================================================
# Epic App Credentials (from https://fhir.epic.com/Developer/Apps)
# =============================================================================

# Production Client ID (use for production Epic environments)
EPIC_CLIENT_ID=your-production-client-id-here

# Non-Production/Sandbox Client ID (use for sandbox testing)
EPIC_CLIENT_ID_SANDBOX=your-sandbox-client-id-here

# Client Secret (for confidential client authentication)
# IMPORTANT: Never commit this value to version control!
EPIC_CLIENT_SECRET=your-client-secret-here

# =============================================================================
# OAuth Configuration
# =============================================================================

# Redirect URI for OAuth callback (must match app registration)
EPIC_REDIRECT_URI=http://localhost:8080/callback

# =============================================================================
# FHIR Server URLs
# =============================================================================

# Epic Sandbox FHIR R4 Base URL
EPIC_FHIR_BASE_URL=https://fhir.epic.com/interconnect-fhir-oauth/api/FHIR/R4

# =============================================================================
# App Metadata
# =============================================================================

# App Name (for reference)
EPIC_APP_NAME=CrossCures CKD Summarizer

# Target Audience
EPIC_APP_AUDIENCE=Clinicians
