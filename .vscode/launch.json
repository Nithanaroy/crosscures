{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug FastAPI (uvicorn)",
            "type": "debugpy",
            "request": "launch",
            "python": "${workspaceFolder}/.venv/bin/python",
            "module": "uvicorn",
            "args": [
                "main:app",
                "--port",
                "8000"
            ],
            "subProcess": true,
            "justMyCode": false,
            "console": "internalConsole",
            "cwd": "${workspaceFolder}/backend"
        }
    ]
}
